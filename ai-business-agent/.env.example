# === LLM Provider Configuratie ===
# Kies je provider: claude_sdk, anthropic, openai, ollama
LLM_PROVIDER=claude_sdk

# Model (optioneel — leeg = provider default)
# Voorbeelden: claude-sonnet-4-6, gpt-4o, llama3.1
LLM_MODEL=

# --- Anthropic (direct API, pay-per-token) ---
ANTHROPIC_API_KEY=

# --- OpenAI / OpenAI-compatible (OpenRouter, Together, etc.) ---
OPENAI_API_KEY=
# Voor OpenRouter: https://openrouter.ai/api/v1
# Voor Together: https://api.together.xyz/v1
OPENAI_BASE_URL=

# --- Ollama (lokaal, gratis) ---
# Zorg dat Ollama draait: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# --- Claude SDK (origineel, vereist Max abonnement) ---
# Geen API key nodig — gebruikt Claude Code CLI auth
# Zorg dat je bent ingelogd: claude login

# === Server Settings ===
HOST=0.0.0.0
PORT=8000

# === Database ===
DATABASE_PATH=data/agent_memory.db

# === API authenticatie ===
API_TOKEN=

# === Obsidian (optioneel) ===
OBSIDIAN_VAULT_PATH=
